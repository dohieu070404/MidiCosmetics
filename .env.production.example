# Midi Cosmetics production/Vercel notes.
# For Vercel, set these values in Vercel Project Settings, not in frontend source.
NODE_ENV=production
APP_NAME=Midi Cosmetics API
API_PREFIX=/api/v1
PORT=8080

# Backend Prisma/Supabase PostgreSQL.
DATABASE_URL=postgresql://postgres.dpajmzyqitrohnutazub:YOUR_PASSWORD_URL_ENCODED@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.dpajmzyqitrohnutazub:YOUR_PASSWORD_URL_ENCODED@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

JWT_ACCESS_SECRET=CHANGE_ME_RANDOM_ACCESS_SECRET_AT_LEAST_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_RANDOM_REFRESH_SECRET_AT_LEAST_32_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

CORS_ORIGIN=https://<FRONTEND_DOMAIN>.vercel.app,https://<CUSTOM_FRONTEND_DOMAIN_IF_ANY>
FRONTEND_URL=https://<FRONTEND_DOMAIN>.vercel.app
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10
LOG_LEVEL=info
LOGGER_PRETTY=false
TRUST_PROXY=true

RUN_MIGRATIONS=false
DATABASE_SYNC_STRATEGY=none
SEED_DATABASE=false
AUTO_RESET_FAILED_MIGRATIONS=false
ALLOW_ADMIN_SEED=false
DEV_ADMIN_EMAIL=
DEV_ADMIN_PASSWORD=
DEV_ADMIN_FULL_NAME=
ADMIN_ALLOWED_EMAILS=<ADMIN_EMAIL>
ADMIN_BOOTSTRAP_TOKEN=CHANGE_ME_RANDOM_BOOTSTRAP_TOKEN_AT_LEAST_32_CHARS
ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_LOGIN_PATH=/quan-tri-midi-secure-2026

UPLOAD_DRIVER=cloudinary
UPLOAD_MAX_FILE_SIZE_MB=5
UPLOAD_IMAGE_MAX_FILE_SIZE_MB=5
UPLOAD_SPREADSHEET_MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads
PUBLIC_UPLOAD_BASE_URL=
CLOUDINARY_CLOUD_NAME=<CLOUDINARY_CLOUD_NAME>
CLOUDINARY_API_KEY=<CLOUDINARY_API_KEY>
CLOUDINARY_API_SECRET=<CLOUDINARY_API_SECRET>

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
ADMIN_ALERT_EMAIL=

# Frontend Vercel env must contain only VITE_* values.
VITE_APP_NAME=Midi Cosmetics
VITE_API_BASE_URL=https://<BACKEND_DOMAIN>.vercel.app/api/v1
VITE_API_ORIGIN=https://<BACKEND_DOMAIN>.vercel.app
VITE_ENABLE_API_MOCKING=false
VITE_ADMIN_LOGIN_PATH=/quan-tri-midi-secure-2026
