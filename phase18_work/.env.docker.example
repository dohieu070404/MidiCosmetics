# Midi Cosmetics local development Docker environment
# Copy to .env before running: docker compose up --build
NODE_ENV=development
TZ=Asia/Bangkok

APP_NAME=Midi Cosmetics API
API_PREFIX=/api/v1
BACKEND_PORT=8080
FRONTEND_PORT=8081

MYSQL_ROOT_PASSWORD=dev_root_password_change_me
MYSQL_DATABASE=midi_cosmetics
MYSQL_USER=midi_user
MYSQL_PASSWORD=dev_mysql_password_change_me
# Optional: only used with docker-compose.dev.yml
MYSQL_PORT=3037

DATABASE_URL=mysql://midi_user:dev_mysql_password_change_me@mysql:3306/midi_cosmetics

JWT_ACCESS_SECRET=dev_access_secret_change_me_minimum_32_chars_123456
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_minimum_32_chars_123456
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

CORS_ORIGIN=http://localhost:8081,http://localhost:5173
FRONTEND_URL=http://localhost:8081
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
LOG_LEVEL=info
LOGGER_PRETTY=false
TRUST_PROXY=true

RUN_MIGRATIONS=true
DATABASE_SYNC_STRATEGY=migrate
SEED_DATABASE=true
AUTO_RESET_FAILED_MIGRATIONS=false

ALLOW_ADMIN_SEED=true
DEV_ADMIN_EMAIL=admin@midicosmetics.local
DEV_ADMIN_PASSWORD=Admin@123456
DEV_ADMIN_FULL_NAME=Midi Admin
ADMIN_ALLOWED_EMAILS=
ADMIN_BOOTSTRAP_TOKEN=
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_LOGIN_PATH=/quan-tri-midi-secure-2026

# Email notification / admin audit alerts
# Leave blank in development if you do not want to send emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
ADMIN_ALERT_EMAIL=

VITE_APP_NAME=Midi Cosmetics
VITE_API_BASE_URL=/api/v1
VITE_API_ORIGIN=http://localhost:8081
VITE_ENABLE_API_MOCKING=false
VITE_ADMIN_LOGIN_PATH=/quan-tri-midi-secure-2026

UPLOAD_DRIVER=local
UPLOAD_MAX_FILE_SIZE_MB=5
UPLOAD_IMAGE_MAX_FILE_SIZE_MB=5
UPLOAD_SPREADSHEET_MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads
PUBLIC_UPLOAD_BASE_URL=http://localhost:8080/uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
