{
  "name": "midi-cosmetics-vercel-fullstack",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "vercel-build": "npm install --prefix backend && npm install --prefix frontend && npm --prefix backend run prisma:generate && npm --prefix frontend run build",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "npm --prefix backend run prisma:generate",
    "check:prisma": "npm --prefix backend exec prisma validate -- --schema=prisma/schema.prisma",
    "lint:frontend": "npm --prefix frontend run lint"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
