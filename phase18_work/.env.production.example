NODE_ENV=production
APP_NAME=Midi Cosmetics API
API_PREFIX=/api/v1
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE

JWT_ACCESS_SECRET=replace_with_64_plus_random_chars
JWT_REFRESH_SECRET=replace_with_64_plus_random_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

CORS_ORIGIN=https://your-vercel-project.vercel.app
FRONTEND_URL=https://your-vercel-project.vercel.app
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
LOG_LEVEL=info
LOGGER_PRETTY=false
TRUST_PROXY=true

SEED_DATABASE=false
ALLOW_ADMIN_SEED=false
DEV_ADMIN_EMAIL=
DEV_ADMIN_PASSWORD=
DEV_ADMIN_FULL_NAME=
ADMIN_ALLOWED_EMAILS=dohieu007042004@gmail.com
ADMIN_BOOTSTRAP_TOKEN=replace_with_random_token_at_least_32_chars
ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_LOGIN_PATH=/quan-tri-midi-secure-2026

UPLOAD_DRIVER=cloudinary
UPLOAD_MAX_FILE_SIZE_MB=5
UPLOAD_IMAGE_MAX_FILE_SIZE_MB=5
UPLOAD_SPREADSHEET_MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads
IMPORT_BATCH_SIZE=100
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Midi Cosmetics <no-reply@your-domain.com>
ADMIN_ALERT_EMAIL=dohieu007042004@gmail.com

VITE_APP_NAME=Midi Cosmetics
VITE_API_BASE_URL=/api/v1
VITE_API_ORIGIN=
VITE_ENABLE_API_MOCKING=false
VITE_ADMIN_LOGIN_PATH=/quan-tri-midi-secure-2026
