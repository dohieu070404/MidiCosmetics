NODE_ENV=development
PORT=8080
APP_NAME=Midi Cosmetics API
API_PREFIX=/api/v1
# Supabase PostgreSQL / Prisma
# DATABASE_URL should use Supabase pooler for runtime/serverless connections.
# DIRECT_URL is for Prisma CLI/migrations only; app runtime must not depend on it.
DATABASE_URL=postgresql://postgres.dpajmzyqitrohnutazub:YOUR_PASSWORD_URL_ENCODED@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.dpajmzyqitrohnutazub:YOUR_PASSWORD_URL_ENCODED@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

JWT_ACCESS_SECRET=dev_access_secret_change_me_minimum_32_chars_123456
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_minimum_32_chars_123456
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

CORS_ORIGIN=http://localhost:5173,http://localhost:8081
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
LOG_LEVEL=debug
LOGGER_PRETTY=true
TRUST_PROXY=false

ALLOW_ADMIN_SEED=true
DEV_ADMIN_EMAIL=admin@midicosmetics.local
DEV_ADMIN_PASSWORD=Admin@123456
DEV_ADMIN_FULL_NAME=Midi Admin
ADMIN_ALLOWED_EMAILS=
ADMIN_BOOTSTRAP_TOKEN=
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_LOGIN_PATH=/quan-tri-midi-secure-2026

# Production/Vercel safety defaults: keep these disabled in runtime.
RUN_MIGRATIONS=false
DATABASE_SYNC_STRATEGY=none
SEED_DATABASE=false
AUTO_RESET_FAILED_MIGRATIONS=false

# Production/Vercel must use Cloudinary because local filesystem is not persistent.
UPLOAD_DRIVER=cloudinary
UPLOAD_MAX_FILE_SIZE_MB=5
UPLOAD_IMAGE_MAX_FILE_SIZE_MB=5
UPLOAD_SPREADSHEET_MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads
PUBLIC_UPLOAD_BASE_URL=http://localhost:8080/uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email notification / admin audit alerts
# Leave blank in development if you do not want to send emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
ADMIN_ALERT_EMAIL=
