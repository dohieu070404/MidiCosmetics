generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum CommentStatus {
  VISIBLE
  HIDDEN
  SPAM
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum MediaProvider {
  LOCAL
  CLOUDINARY
}

enum SettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

model User {
  id                BigInt     @id @default(autoincrement()) @map("id")
  uuid              String     @unique @default(uuid()) @db.Char(36) @map("uuid")
  email             String     @unique @db.VarChar(191) @map("email")
  passwordHash      String     @db.VarChar(255) @map("password_hash")
  fullName          String     @db.VarChar(150) @map("full_name")
  phone             String?    @db.VarChar(30) @map("phone")
  avatarUrl         String?    @db.VarChar(500) @map("avatar_url")
  role              UserRole   @default(USER) @map("role")
  status            UserStatus @default(ACTIVE) @map("status")
  emailVerifiedAt   DateTime?  @map("email_verified_at")
  passwordChangedAt DateTime?  @map("password_changed_at")
  lastLoginAt       DateTime?  @map("last_login_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  deletedAt         DateTime?  @map("deleted_at")

  refreshTokens           RefreshToken[]
  adminVerificationTokens AdminVerificationToken[]
  posts                   BlogPost[]
  blogLikes     BlogLike[]
  comments      Comment[]
  importJobs    ImportJob[]
  mediaAssets   MediaAsset[]
  auditLogs     AuditLog[]

  @@index([role], map: "idx_users_role")
  @@index([status], map: "idx_users_status")
  @@index([deletedAt], map: "idx_users_deleted_at")
  @@index([createdAt], map: "idx_users_created_at")
  @@map("users")
}

model RefreshToken {
  id        BigInt    @id @default(autoincrement()) @map("id")
  uuid      String    @unique @db.Char(36) @map("uuid")
  userId    BigInt    @map("user_id")
  tokenHash String    @unique @db.Char(64) @map("token_hash")
  userAgent String?   @db.VarChar(500) @map("user_agent")
  ipAddress String?   @db.VarChar(64) @map("ip_address")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_refresh_tokens_user_id")
  @@index([expiresAt], map: "idx_refresh_tokens_expires_at")
  @@index([revokedAt], map: "idx_refresh_tokens_revoked_at")
  @@map("refresh_tokens")
}

model AdminVerificationToken {
  id                  BigInt    @id @default(autoincrement()) @map("id")
  uuid                String    @unique @default(uuid()) @db.Char(36) @map("uuid")
  adminId             BigInt    @map("admin_id")
  type                String    @db.VarChar(80) @map("type")
  tokenHash           String    @unique @db.Char(64) @map("token_hash")
  pendingPasswordHash String?   @db.VarChar(255) @map("pending_password_hash")
  targetEmail         String?   @db.VarChar(191) @map("target_email")
  expiresAt           DateTime  @map("expires_at")
  usedAt              DateTime? @map("used_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, type], map: "idx_admin_verification_tokens_admin_type")
  @@index([expiresAt], map: "idx_admin_verification_tokens_expires_at")
  @@index([usedAt], map: "idx_admin_verification_tokens_used_at")
  @@map("admin_verification_tokens")
}

model NotificationRecipient {
  id         BigInt    @id @default(autoincrement()) @map("id")
  uuid       String    @unique @default(uuid()) @db.Char(36) @map("uuid")
  email      String    @unique @db.VarChar(191) @map("email")
  isVerified Boolean   @default(false) @map("is_verified")
  verifiedAt DateTime? @map("verified_at")
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@index([isVerified, isActive], map: "idx_notification_recipients_verified_active")
  @@index([deletedAt], map: "idx_notification_recipients_deleted_at")
  @@map("notification_recipients")
}

model EmailLog {
  id           BigInt   @id @default(autoincrement()) @map("id")
  uuid         String   @unique @default(uuid()) @db.Char(36) @map("uuid")
  type         String   @db.VarChar(100) @map("type")
  to           String   @db.VarChar(191) @map("to_email")
  subject      String   @db.VarChar(255) @map("subject")
  status       String   @db.VarChar(40) @map("status")
  errorMessage String?  @db.VarChar(500) @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([type], map: "idx_email_logs_type")
  @@index([status], map: "idx_email_logs_status")
  @@index([createdAt], map: "idx_email_logs_created_at")
  @@map("email_logs")
}

model MediaAsset {
  id           BigInt        @id @default(autoincrement()) @map("id")
  uuid         String        @unique @default(uuid()) @db.Char(36) @map("uuid")
  uploaderId   BigInt?       @map("uploader_id")
  provider     MediaProvider @default(LOCAL) @map("provider")
  publicId     String?       @db.VarChar(255) @map("public_id")
  originalName String        @db.VarChar(255) @map("original_name")
  fileName     String?       @db.VarChar(255) @map("file_name")
  mimeType     String        @db.VarChar(100) @map("mime_type")
  sizeBytes    BigInt        @map("size_bytes")
  width        Int?          @map("width")
  height       Int?          @map("height")
  secureUrl    String        @db.VarChar(1000) @map("secure_url")
  altText      String?       @db.VarChar(255) @map("alt_text")
  metadata     Json?         @map("metadata")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  deletedAt    DateTime?     @map("deleted_at")

  uploader      User?          @relation(fields: [uploaderId], references: [id], onDelete: SetNull)
  featuredPosts BlogPost[]     @relation("PostFeaturedImage")
  productImages ProductImage[]

  @@index([uploaderId], map: "idx_media_assets_uploader_id")
  @@index([provider], map: "idx_media_assets_provider")
  @@index([deletedAt], map: "idx_media_assets_deleted_at")
  @@map("media_assets")
}

model BlogCategory {
  id          BigInt    @id @default(autoincrement()) @map("id")
  uuid        String    @unique @default(uuid()) @db.Char(36) @map("uuid")
  parentId    BigInt?   @map("parent_id")
  name        String    @db.VarChar(150) @map("name")
  slug        String    @unique @db.VarChar(191) @map("slug")
  description String?   @db.Text @map("description")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  parent   BlogCategory?  @relation("BlogCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children BlogCategory[] @relation("BlogCategoryTree")
  posts    BlogPost[]

  @@index([parentId], map: "idx_blog_categories_parent_id")
  @@index([sortOrder], map: "idx_blog_categories_sort_order")
  @@index([deletedAt], map: "idx_blog_categories_deleted_at")
  @@map("blog_categories")
}

model BlogTag {
  id        BigInt    @id @default(autoincrement()) @map("id")
  uuid      String    @unique @default(uuid()) @db.Char(36) @map("uuid")
  name      String    @db.VarChar(100) @map("name")
  slug      String    @unique @db.VarChar(191) @map("slug")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  posts BlogPostTag[]

  @@index([deletedAt], map: "idx_blog_tags_deleted_at")
  @@map("blog_tags")
}

model BlogPost {
  id              BigInt     @id @default(autoincrement()) @map("id")
  uuid            String     @unique @default(uuid()) @db.Char(36) @map("uuid")
  authorId        BigInt     @map("author_id")
  categoryId      BigInt?    @map("category_id")
  featuredImageId BigInt?    @map("featured_image_id")
  title           String     @db.VarChar(255) @map("title")
  slug            String     @unique @db.VarChar(191) @map("slug")
  excerpt         String?    @db.VarChar(500) @map("excerpt")
  content         String     @db.Text @map("content")
  status          PostStatus @default(DRAFT) @map("status")
  isFeatured      Boolean    @default(false) @map("is_featured")
  featuredOrder   Int        @default(0) @map("featured_order")
  readingMinutes  Int        @default(1) @map("reading_minutes")
  viewCount       Int        @default(0) @map("view_count")
  seoTitle        String?    @db.VarChar(255) @map("seo_title")
  seoDescription  String?    @db.VarChar(500) @map("seo_description")
  publishedAt     DateTime?  @map("published_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  deletedAt       DateTime?  @map("deleted_at")

  author        User          @relation(fields: [authorId], references: [id], onDelete: Restrict)
  category      BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  featuredImage MediaAsset?   @relation("PostFeaturedImage", fields: [featuredImageId], references: [id], onDelete: SetNull)
  tags          BlogPostTag[]
  comments      Comment[]
  likes         BlogLike[]

  @@index([authorId], map: "idx_blog_posts_author_id")
  @@index([categoryId], map: "idx_blog_posts_category_id")
  @@index([featuredImageId], map: "idx_blog_posts_featured_image_id")
  @@index([status, publishedAt], map: "idx_blog_posts_status_published_at")
  @@index([isFeatured, featuredOrder], map: "idx_blog_posts_featured_order")
  @@index([deletedAt], map: "idx_blog_posts_deleted_at")
  @@map("blog_posts")
}

model BlogLike {
  id        BigInt   @id @default(autoincrement()) @map("id")
  uuid      String   @unique @default(uuid()) @db.Char(36) @map("uuid")
  postId    BigInt   @map("post_id")
  userId    BigInt?  @map("user_id")
  ipHash    String?  @db.Char(64) @map("ip_hash")
  createdAt DateTime @default(now()) @map("created_at")

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([postId, userId], map: "uq_blog_likes_post_user")
  @@unique([postId, ipHash], map: "uq_blog_likes_post_ip")
  @@index([postId], map: "idx_blog_likes_post_id")
  @@index([userId], map: "idx_blog_likes_user_id")
  @@map("blog_likes")
}

model BlogPostTag {
  postId    BigInt   @map("post_id")
  tagId     BigInt   @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId], map: "idx_blog_post_tags_tag_id")
  @@map("blog_post_tags")
}

model ProductBrand {
  id          BigInt    @id @default(autoincrement()) @map("id")
  uuid        String    @unique @default(uuid()) @db.Char(36) @map("uuid")
  name        String    @db.VarChar(150) @map("name")
  slug        String    @unique @db.VarChar(191) @map("slug")
  description String?   @db.Text @map("description")
  logoUrl     String?   @db.VarChar(1000) @map("logo_url")
  country     String?   @db.VarChar(100) @map("country")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  products Product[]

  @@index([sortOrder], map: "idx_product_brands_sort_order")
  @@index([deletedAt], map: "idx_product_brands_deleted_at")
  @@map("product_brands")
}

model ProductCategory {
  id          BigInt    @id @default(autoincrement()) @map("id")
  uuid        String    @unique @default(uuid()) @db.Char(36) @map("uuid")
  parentId    BigInt?   @map("parent_id")
  name        String    @db.VarChar(150) @map("name")
  slug        String    @unique @db.VarChar(191) @map("slug")
  description String?   @db.Text @map("description")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  parent   ProductCategory?  @relation("ProductCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children ProductCategory[] @relation("ProductCategoryTree")
  products Product[]

  @@index([parentId], map: "idx_product_categories_parent_id")
  @@index([sortOrder], map: "idx_product_categories_sort_order")
  @@index([deletedAt], map: "idx_product_categories_deleted_at")
  @@map("product_categories")
}

model ProductCollection {
  id          BigInt    @id @default(autoincrement()) @map("id")
  uuid        String    @unique @default(uuid()) @db.Char(36) @map("uuid")
  name        String    @db.VarChar(150) @map("name")
  slug        String    @unique @db.VarChar(191) @map("slug")
  description String?   @db.Text @map("description")
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  products ProductCollectionItem[]

  @@index([isActive, sortOrder], map: "idx_product_collections_active_sort_order")
  @@index([deletedAt], map: "idx_product_collections_deleted_at")
  @@map("product_collections")
}

model Product {
  id               BigInt        @id @default(autoincrement()) @map("id")
  uuid             String        @unique @default(uuid()) @db.Char(36) @map("uuid")
  categoryId       BigInt?       @map("category_id")
  brandId          BigInt?       @map("brand_id")
  name             String        @db.VarChar(255) @map("name")
  slug             String        @unique @db.VarChar(191) @map("slug")
  sku              String?       @unique @db.VarChar(100) @map("sku")
  barcode          String?       @db.VarChar(100) @map("barcode")
  shortDescription String?       @db.VarChar(500) @map("short_description")
  description      String?       @db.Text @map("description")
  skinType         String?       @db.VarChar(120) @map("skin_type")
  ingredients      String?       @db.Text @map("ingredients")
  howToUse         String?       @db.Text @map("how_to_use")
  benefits         String?       @db.Text @map("benefits")
  caution          String?       @db.Text @map("caution")
  price            Decimal       @default(0) @db.Decimal(12, 2) @map("price")
  stock            Int           @default(0) @map("stock")
  unit             String?       @db.VarChar(50) @map("unit")
  compareAtPrice   Decimal?      @db.Decimal(12, 2) @map("compare_at_price")
  currency         String        @default("VND") @db.Char(3) @map("currency")
  status           ProductStatus @default(DRAFT) @map("status")
  isFeatured       Boolean       @default(false) @map("is_featured")
  featuredOrder    Int           @default(0) @map("featured_order")
  viewCount        Int           @default(0) @map("view_count")
  sortOrder        Int           @default(0) @map("sort_order")
  seoTitle         String?       @db.VarChar(255) @map("seo_title")
  seoDescription   String?       @db.VarChar(500) @map("seo_description")
  publishedAt      DateTime?     @map("published_at")
  rawImportData    Json?         @map("raw_import_data")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  deletedAt        DateTime?     @map("deleted_at")

  category    ProductCategory?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand       ProductBrand?           @relation(fields: [brandId], references: [id], onDelete: SetNull)
  images      ProductImage[]
  comments    Comment[]
  collections ProductCollectionItem[]

  @@index([categoryId], map: "idx_products_category_id")
  @@index([brandId], map: "idx_products_brand_id")
  @@index([barcode], map: "idx_products_barcode")
  @@index([stock], map: "idx_products_stock")
  @@index([status, publishedAt], map: "idx_products_status_published_at")
  @@index([isFeatured, featuredOrder], map: "idx_products_featured_order")
  @@index([skinType], map: "idx_products_skin_type")
  @@index([viewCount], map: "idx_products_view_count")
  @@index([deletedAt], map: "idx_products_deleted_at")
  @@map("products")
}

model ProductCollectionItem {
  collectionId BigInt   @map("collection_id")
  productId    BigInt   @map("product_id")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  collection ProductCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product    Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([collectionId, productId])
  @@index([productId], map: "idx_product_collection_items_product_id")
  @@map("product_collection_items")
}

model ProductImage {
  id           BigInt   @id @default(autoincrement()) @map("id")
  productId    BigInt   @map("product_id")
  mediaAssetId BigInt   @map("media_asset_id")
  altText      String?  @db.VarChar(255) @map("alt_text")
  sortOrder    Int      @default(0) @map("sort_order")
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  mediaAsset MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Restrict)

  @@unique([productId, mediaAssetId], map: "uq_product_images_product_media")
  @@index([productId, sortOrder], map: "idx_product_images_product_sort_order")
  @@index([mediaAssetId], map: "idx_product_images_media_asset_id")
  @@map("product_images")
}

model Comment {
  id          BigInt        @id @default(autoincrement()) @map("id")
  uuid        String        @unique @default(uuid()) @db.Char(36) @map("uuid")
  postId      BigInt?       @map("post_id")
  productId   BigInt?       @map("product_id")
  userId      BigInt?       @map("user_id")
  parentId    BigInt?       @map("parent_id")
  authorName  String        @db.VarChar(150) @map("author_name")
  authorEmail String        @db.VarChar(191) @map("author_email")
  content     String        @db.Text @map("content")
  status      CommentStatus @default(VISIBLE) @map("status")
  ipAddress   String?       @db.VarChar(64) @map("ip_address")
  userAgent   String?       @db.VarChar(500) @map("user_agent")
  moderatedAt DateTime?     @map("moderated_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  post    BlogPost? @relation(fields: [postId], references: [id], onDelete: Cascade)
  product Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([postId, status], map: "idx_comments_post_status")
  @@index([productId, status], map: "idx_comments_product_status")
  @@index([userId], map: "idx_comments_user_id")
  @@index([parentId], map: "idx_comments_parent_id")
  @@index([status, createdAt], map: "idx_comments_status_created_at")
  @@index([deletedAt], map: "idx_comments_deleted_at")
  @@map("comments")
}

model ImportJob {
  id           BigInt       @id @default(autoincrement()) @map("id")
  uuid         String       @unique @default(uuid()) @db.Char(36) @map("uuid")
  createdById  BigInt?      @map("created_by_id")
  type         String       @db.VarChar(100) @map("type")
  originalName String       @db.VarChar(255) @map("original_name")
  fileUrl      String?      @db.VarChar(1000) @map("file_url")
  status       ImportStatus @default(PENDING) @map("status")
  totalRows    Int          @default(0) @map("total_rows")
  successRows  Int          @default(0) @map("success_rows")
  failedRows   Int          @default(0) @map("failed_rows")
  errorReport  Json?        @map("error_report")
  startedAt    DateTime?    @map("started_at")
  completedAt  DateTime?    @map("completed_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)
  rows      ImportRow[]

  @@index([createdById], map: "idx_import_jobs_created_by_id")
  @@index([type, status], map: "idx_import_jobs_type_status")
  @@index([deletedAt], map: "idx_import_jobs_deleted_at")
  @@map("import_jobs")
}

model ImportRow {
  id          BigInt   @id @default(autoincrement()) @map("id")
  uuid        String   @unique @default(uuid()) @db.Char(36) @map("uuid")
  importJobId BigInt   @map("import_job_id")
  rowNumber   Int      @map("row_number")
  sku         String?  @db.VarChar(100) @map("sku")
  status      String   @db.VarChar(30) @map("status")
  message     String?  @db.Text @map("message")
  warnings    Json?    @map("warnings")
  errors      Json?    @map("errors")
  rawData     Json?    @map("raw_data")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@unique([importJobId, rowNumber], map: "uq_import_rows_job_row")
  @@index([importJobId], map: "idx_import_rows_import_job_id")
  @@index([sku], map: "idx_import_rows_sku")
  @@index([status], map: "idx_import_rows_status")
  @@map("import_rows")
}

model SiteSetting {
  id          BigInt      @id @default(autoincrement()) @map("id")
  key         String      @unique @db.VarChar(120) @map("setting_key")
  value       Json        @map("setting_value")
  type        SettingType @default(STRING) @map("setting_type")
  group       String      @default("general") @db.VarChar(80) @map("setting_group")
  description String?     @db.VarChar(255) @map("description")
  isPublic    Boolean     @default(false) @map("is_public")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([group], map: "idx_site_settings_group")
  @@index([isPublic], map: "idx_site_settings_is_public")
  @@map("site_settings")
}

model AuditLog {
  id           BigInt   @id @default(autoincrement()) @map("id")
  uuid         String   @unique @default(uuid()) @db.Char(36) @map("uuid")
  actorId      BigInt?  @map("actor_id")
  actorEmail   String?  @db.VarChar(191) @map("actor_email")
  action       String   @db.VarChar(120) @map("action")
  entityType   String   @db.VarChar(120) @map("entity_type")
  entityId     String?  @db.VarChar(120) @map("entity_id")
  beforeData   Json?    @map("before_data")
  afterData    Json?    @map("after_data")
  metadata     Json?    @map("metadata")
  ipAddress    String?  @db.VarChar(64) @map("ip_address")
  userAgent    String?  @db.VarChar(500) @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId], map: "idx_audit_logs_actor_id")
  @@index([actorEmail], map: "idx_audit_logs_actor_email")
  @@index([entityType, entityId], map: "idx_audit_logs_entity")
  @@index([createdAt], map: "idx_audit_logs_created_at")
  @@map("audit_logs")
}
