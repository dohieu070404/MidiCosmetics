# Midi Cosmetics local Docker environment WITHOUT local database container.
# Copy to .env before running: docker compose up --build
# Backend DATABASE_URL/DIRECT_URL are loaded from backend/.env and connect directly to Supabase.
NODE_ENV=development
TZ=Asia/Bangkok
BACKEND_PORT=8080
FRONTEND_PORT=8081

VITE_APP_NAME=Midi Cosmetics
VITE_API_BASE_URL=/api/v1
VITE_API_ORIGIN=http://localhost:8081
VITE_ENABLE_API_MOCKING=false
VITE_ADMIN_LOGIN_PATH=/quan-tri-midi-secure-2026
