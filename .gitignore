```gitignore
# =========================
# Environment files / Secrets
# =========================

.env
.env.*
!.env.example
!.env.*.example

**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

# Local env files
.env.local
.env.development
.env.production
.env.test
.env.docker

backend/.env
backend/.env.*
!backend/.env.example
!backend/.env.*.example

frontend/.env
frontend/.env.*
!frontend/.env.example
!frontend/.env.*.example

# Vercel local config
.vercel

# =========================
# Dependencies
# =========================

node_modules
**/node_modules

.pnpm-store
.yarn
.yarn/cache
.yarn/unplugged

# =========================
# Build outputs
# =========================

dist
build
.out
.next
.output

frontend/dist
frontend/build
backend/dist
backend/build

# =========================
# Logs
# =========================

logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =========================
# Runtime / uploads
# =========================

uploads
backend/uploads
tmp
temp
.cache

# Uploaded files
*.tmp
*.temp

# =========================
# Database / local data
# =========================

*.sqlite
*.sqlite3
*.db
*.dump
*.sql.gz
*.backup

# Docker local volumes / data
docker-data
data
postgres_data
mysql_data

# =========================
# Prisma
# =========================

# Do NOT ignore:
# backend/prisma/schema.prisma
# backend/prisma/migrations

# Optional local Prisma artifacts
prisma/dev.db
backend/prisma/dev.db

# =========================
# OS / Editor
# =========================

.DS_Store
Thumbs.db

.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json

.idea

# =========================
# Test / coverage
# =========================

coverage
.nyc_output

# =========================
# Misc
# =========================

*.tgz
*.zip
*.rar
*.7z

# Keep project source clean
*.bak
*.swp
```
